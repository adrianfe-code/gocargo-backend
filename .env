# ── dLocal ──────────────────────────────────────────────────
# Obtenelas en dashboard.dlocal.com → Settings → API Keys
# Usar sandbox para pruebas, api.dlocal.com para producción
DLOCAL_API_URL=https://sandbox.dlocal.com
DLOCAL_X_LOGIN=TU_X_LOGIN
DLOCAL_X_TRANS_KEY=TU_X_TRANS_KEY
DLOCAL_SECRET_KEY=TU_SECRET_KEY

# ── App ─────────────────────────────────────────────────────
# URL pública de este backend (la que te da Railway)
BACKEND_URL=https://TU-APP.up.railway.app
PORT=3001
